# =============================================================
# LLM / OpenAI 连接配置（必填）
# =============================================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# =============================================================
# 教材自动加载（可选）
# MATERIALS_AUTOLOAD: true 时启动即将 MATERIALS_DIR 里的文件注入每个会话的系统上下文
# MATERIALS_MAX_FILES: 最多加载的文件数（最小 1）
# MATERIALS_MAX_EXCERPT_CHARS: 每份材料注入的最大字符数（最小 200）
# =============================================================
MATERIALS_AUTOLOAD=true
MATERIALS_DIR=materials
MATERIALS_MAX_FILES=20
MATERIALS_MAX_EXCERPT_CHARS=1200

# =============================================================
# 附件提取大小控制（可选）
# ATTACHMENT_EXCERPT_CHARS: 存入 meta.excerpt 的最大字符数，0 = 不限制（全量送模型）
# ATTACHMENT_HINT_CHARS:    仅用于服务端日志中的摘要预览，不影响模型入参
# =============================================================
ATTACHMENT_EXCERPT_CHARS=0
ATTACHMENT_HINT_CHARS=800

# =============================================================
# Excel / Spreadsheet 提取行列上限（可选）
# 0 = 不限制（全量提取），适合大表；设置正整数可做硬上限保护内存
# =============================================================
SPREADSHEET_RAW_ROW_LIMIT=0
SPREADSHEET_RAW_COL_LIMIT=0

# =============================================================
# 上下文预算裁剪（可选）
# LLM_MAX_HISTORY_CHARS: 每次请求发给模型的上下文最大字符数，0=不限制
#   默认 40000（≈1 万 token），超出时优先裁剪最旧的预置示例对话
#   附件内容和近期真实对话轮次永远不会被裁剪
# LLM_MIN_RECENT_TURNS: 无论预算如何，至少保留最近 N 轮真实对话（默认 6）
# =============================================================
LLM_MAX_HISTORY_CHARS=40000
LLM_MIN_RECENT_TURNS=6

# =============================================================
# 模型入参调试日志（可选，仅排查附件是否送达时开启）
# LLM_PAYLOAD_DEBUG: 开启后每次请求在日志里打印入模字符数、附件摘要长度、消息头尾预览
# LLM_PAYLOAD_PREVIEW_CHARS: 头/尾预览字符数（最小 50）
# 注意：内容可能包含用户数据，生产环境请保持 false
# =============================================================
LLM_PAYLOAD_DEBUG=false
LLM_PAYLOAD_PREVIEW_CHARS=180

# =============================================================
# 日志配置（可选，loguru）
# LOG_LEVEL: DEBUG / INFO / WARNING / ERROR
# LOG_JSON:  true 输出结构化 JSON 日志，方便日志平台采集
# =============================================================
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_ROTATION=1 day
LOG_RETENTION=14 days
LOG_JSON=false

# =============================================================
# CORS 配置（可选）
# CORS_ALLOW_ORIGINS: 逗号分隔的允许来源；本地测试可设 *
# CORS_ALLOW_ORIGIN_REGEX: 正则扩展来源（默认已覆盖 localhost 与私有网段）
# =============================================================
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|10\.(?:\d{1,3}\.){2}\d{1,3}|192\.168\.(?:\d{1,3})\.(?:\d{1,3})|172\.(?:1[6-9]|2\d|3[0-1])\.(?:\d{1,3})\.(?:\d{1,3}))(?::\d+)?$