OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: auto-load textbook/review materials into every new session.
MATERIALS_AUTOLOAD=true
MATERIALS_DIR=materials
MATERIALS_MAX_FILES=20
MATERIALS_MAX_EXCERPT_CHARS=1200

# Optional: attachment extraction size limits.
# Set ATTACHMENT_EXCERPT_CHARS=0 to send full extracted text to the model.
ATTACHMENT_EXCERPT_CHARS=0
ATTACHMENT_HINT_CHARS=800

# Optional: show "附件: <name> (<size> bytes)" meta header in attachment hints.
# Defaults to false; set to true/1/yes only for debugging.
ATTACHMENT_SHOW_META=false

# Optional: LLM payload diagnostics (for checking whether attachment text reaches model input).
# Keep disabled in normal usage to avoid logging large/sensitive content.
LLM_PAYLOAD_DEBUG=false
LLM_PAYLOAD_PREVIEW_CHARS=180

# Optional: logging settings (loguru)
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_ROTATION=1 day
LOG_RETENTION=14 days
LOG_JSON=false

# Comma-separated frontend origins for CORS. Use * for open access in local tests.
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Optional regex for additional CORS origins (defaults already include localhost and private-network IP ranges).
# CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|10\.(?:\d{1,3}\.){2}\d{1,3}|192\.168\.(?:\d{1,3})\.(?:\d{1,3})|172\.(?:1[6-9]|2\d|3[0-1])\.(?:\d{1,3})\.(?:\d{1,3}))(?::\d+)?$



# Database (PostgreSQL with asyncpg driver)
DATABASE_URL=postgresql+asyncpg://gangbiao:gangbiao@localhost:5432/gangbiao

# JWT authentication
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
# 1. 直接给建议；(强制给答案)
# 2. 易用性和用户体验；✅
# 3. excel解析异常；✅
