OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: auto-load textbook/review materials into every new session.
MATERIALS_AUTOLOAD=true
MATERIALS_DIR=materials
MATERIALS_MAX_FILES=20
MATERIALS_MAX_EXCERPT_CHARS=1200

# Optional: attachment extraction size limits.
# Set ATTACHMENT_EXCERPT_CHARS=0 to send full extracted text to the model.
ATTACHMENT_EXCERPT_CHARS=0
ATTACHMENT_HINT_CHARS=0

# Optional: max upload size per attachment in bytes. 0 = no limit.
# Default: 20971520 (20 MB). Uploads exceeding this are rejected with HTTP 400.
CHAT_ATTACHMENT_MAX_BYTES=20971520

# Optional: spreadsheet extraction limits. 0 = no limit (extract full sheet).
SPREADSHEET_RAW_ROW_LIMIT=0
SPREADSHEET_RAW_COL_LIMIT=0

# Optional: show "附件: <name> (<size> bytes)" meta header in attachment hints.
# Defaults to false; set to true/1/yes only for debugging.
ATTACHMENT_SHOW_META=false

# Optional: LLM payload diagnostics (for checking whether attachment text reaches model input).
# Keep disabled in normal usage to avoid logging large/sensitive content.
LLM_PAYLOAD_DEBUG=false
LLM_PAYLOAD_PREVIEW_CHARS=180

# Optional: logging settings (loguru)
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_ROTATION=1 day
LOG_RETENTION=14 days
LOG_JSON=false

# Comma-separated frontend origins for CORS. Use * for open access in local tests.
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Optional regex for additional CORS origins (defaults already include localhost and private-network IP ranges).
# CORS_ALLOW_ORIGIN_REGEX=



# Database (PostgreSQL with asyncpg driver)
POSTGRES_PASSWORD=gangbiao_dev
DATABASE_URL=postgresql+asyncpg://gangbiao:gangbiao@localhost:5432/gangbiao

# --- CAS / SSO ---
# auth_mode: "sso" | "local" | "both" (default: both)
AUTH_MODE=both
SID_BASE_URL=https://sid.ruijie.com.cn
SID_SERVICE_URL=https://gangbiao-ai-coach.ruijie.com.cn/login
SID_LOGOUT_URL=https://sid.ruijie.com.cn/logout
SESSION_COOKIE_NAME=sid_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_TTL_HOURS=8
SESSION_SLIDING_REFRESH_MINUTES=30
CAS_VALIDATE_TIMEOUT_SECONDS=5

# Comma-separated SSO employee numbers that should become administrators.
# Example: ADMIN_EMPLOYEE_NOS=10001,10002
ADMIN_EMPLOYEE_NOS=

# --- CSRF ---
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token

# --- Session cleanup ---
SESSION_CLEANUP_INTERVAL_MINUTES=60
SESSION_CLEANUP_GRACE_DAYS=1
